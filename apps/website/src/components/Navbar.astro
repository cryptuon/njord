---
const navLinks: { name: string; path: string; external?: boolean }[] = [
  { name: 'How It Works', path: '/how-it-works' },
  { name: 'Blog', path: '/blog' },
  { name: 'Docs', path: 'https://docs.cryptuon.com/njord', external: true },
]

const ecosystemLinks = [
  { name: 'For Affiliates', path: '/affiliates' },
  { name: 'For Companies', path: '/companies' },
  { name: 'For Bridges', path: '/bridges' },
  { name: 'Campaigns', path: '/campaigns' },
]

const moreLinks = [
  { name: 'Tokenomics', path: '/tokenomics' },
  { name: 'Fraud Protection', path: '/fraud-protection' },
  { name: 'Network Stats', path: '/stats' },
  { name: 'Roadmap', path: '/roadmap' },
  { name: 'Getting Started', path: '/getting-started' },
]

const currentPath = Astro.url.pathname
---

<!-- Devnet Banner -->
<div class="bg-njord-600/20 border-b border-njord-700/30">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-1.5 text-center">
    <p class="text-xs text-njord-300">
      <span class="inline-block w-1.5 h-1.5 rounded-full bg-njord-400 mr-1.5 animate-pulse"></span>
      Njord Protocol is currently in development on Solana Devnet.
      <a href="/roadmap" class="underline hover:text-white ml-1">View Roadmap &rarr;</a>
    </p>
  </div>
</div>

<nav class="glass sticky top-0 z-50 border-b border-surface-700/50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-14">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2">
        <div class="w-7 h-7 rounded-lg bg-gradient-to-br from-njord-400 to-njord-600 flex items-center justify-center">
          <span class="text-white font-bold text-xs">N</span>
        </div>
        <span class="text-white font-bold text-base hidden sm:block">Njord</span>
      </a>

      <!-- Desktop Nav -->
      <div class="hidden lg:flex items-center gap-1">
        {navLinks.map(link => (
          <a
            href={link.path}
            {...(link.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
            class:list={[
              'px-3 py-1.5 rounded-lg text-sm transition-colors',
              !link.external && (currentPath === link.path || (link.path !== '/' && currentPath.startsWith(link.path)))
                ? 'text-njord-400 font-semibold bg-njord-600/10'
                : 'text-gray-400 hover:text-white hover:bg-surface-800',
            ]}
          >
            {link.name}
            {link.external && (
              <svg class="w-3 h-3 inline ml-0.5 -mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
            )}
          </a>
        ))}

        <!-- Ecosystem Dropdown -->
        <div class="relative" id="ecosystem-dropdown">
          <button
            id="ecosystem-toggle"
            class="px-3 py-1.5 rounded-lg text-sm text-gray-400 hover:text-white hover:bg-surface-800 transition-colors flex items-center gap-1"
          >
            Ecosystem
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div
            id="ecosystem-menu"
            class="hidden absolute top-full mt-1 left-0 w-44 py-1.5 bg-surface-800 border border-surface-700 rounded-xl shadow-xl"
          >
            {ecosystemLinks.map(link => (
              <a
                href={link.path}
                class="block px-3 py-1.5 text-sm text-gray-400 hover:text-white hover:bg-surface-700 transition-colors"
              >
                {link.name}
              </a>
            ))}
          </div>
        </div>

        <!-- More Dropdown -->
        <div class="relative" id="more-dropdown">
          <button
            id="more-toggle"
            class="px-3 py-1.5 rounded-lg text-sm text-gray-400 hover:text-white hover:bg-surface-800 transition-colors flex items-center gap-1"
          >
            More
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div
            id="more-menu"
            class="hidden absolute top-full mt-1 right-0 w-44 py-1.5 bg-surface-800 border border-surface-700 rounded-xl shadow-xl"
          >
            {moreLinks.map(link => (
              <a
                href={link.path}
                class="block px-3 py-1.5 text-sm text-gray-400 hover:text-white hover:bg-surface-700 transition-colors"
              >
                {link.name}
              </a>
            ))}
          </div>
        </div>
      </div>

      <!-- Right Side -->
      <div class="flex items-center gap-2">
        <a href="https://github.com/njord-protocol" target="_blank" rel="noopener noreferrer" class="p-1.5 text-gray-400 hover:text-white transition-colors hidden sm:block" title="GitHub">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
        </a>
        <a href="/dashboard" class="btn-primary !py-1.5 !px-4 text-sm hidden sm:inline-flex">Launch App</a>
        <!-- Mobile Menu Toggle -->
        <button id="mobile-toggle" class="lg:hidden p-2 text-gray-400 hover:text-white">
          <svg id="menu-open-icon" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg id="menu-close-icon" class="w-5 h-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Nav -->
  <div id="mobile-nav" class="hidden lg:hidden border-t border-surface-700">
    <div class="px-4 py-3 space-y-0.5">
      <p class="px-3 pt-2 pb-1 text-xs font-semibold text-gray-500 uppercase tracking-wider">Navigate</p>
      {navLinks.map(link => (
        <a
          href={link.path}
          class:list={[
            'block px-3 py-2 rounded-lg text-sm transition-colors',
            currentPath === link.path
              ? 'text-njord-400 bg-njord-600/10'
              : 'text-gray-400 hover:text-white hover:bg-surface-700',
          ]}
        >
          {link.name}
        </a>
      ))}
      <p class="px-3 pt-3 pb-1 text-xs font-semibold text-gray-500 uppercase tracking-wider">Ecosystem</p>
      {ecosystemLinks.map(link => (
        <a
          href={link.path}
          class="block px-3 py-2 rounded-lg text-sm text-gray-400 hover:text-white hover:bg-surface-700 transition-colors"
        >
          {link.name}
        </a>
      ))}
      <p class="px-3 pt-3 pb-1 text-xs font-semibold text-gray-500 uppercase tracking-wider">More</p>
      {moreLinks.map(link => (
        <a
          href={link.path}
          class="block px-3 py-2 rounded-lg text-sm text-gray-400 hover:text-white hover:bg-surface-700 transition-colors"
        >
          {link.name}
        </a>
      ))}
      <p class="px-3 pt-3 pb-1 text-xs font-semibold text-gray-500 uppercase tracking-wider">Resources</p>
      <a
        href="https://docs.cryptuon.com/njord"
        target="_blank"
        rel="noopener noreferrer"
        class="block px-3 py-2 rounded-lg text-sm text-gray-400 hover:text-white hover:bg-surface-700 transition-colors"
      >
        Documentation &nearr;
      </a>
      <a
        href="https://github.com/njord-protocol"
        target="_blank"
        rel="noopener noreferrer"
        class="block px-3 py-2 rounded-lg text-sm text-gray-400 hover:text-white hover:bg-surface-700 transition-colors"
      >
        GitHub &nearr;
      </a>
      <div class="pt-2">
        <a
          href="/dashboard"
          class="block px-3 py-2 rounded-lg text-sm text-njord-400 font-medium hover:bg-surface-700 transition-colors"
        >
          Launch App &rarr;
        </a>
      </div>
    </div>
  </div>
</nav>

<script>
  // Dropdown helper
  function setupDropdown(toggleId: string, menuId: string, containerId: string) {
    const toggle = document.getElementById(toggleId)
    const menu = document.getElementById(menuId)
    if (!toggle || !menu) return
    toggle.addEventListener('click', () => {
      // Close other dropdowns first
      document.querySelectorAll('[id$="-menu"]').forEach(m => {
        if (m !== menu) m.classList.add('hidden')
      })
      menu.classList.toggle('hidden')
    })
    document.addEventListener('click', (e) => {
      if (!document.getElementById(containerId)?.contains(e.target as Node)) {
        menu.classList.add('hidden')
      }
    })
  }

  setupDropdown('ecosystem-toggle', 'ecosystem-menu', 'ecosystem-dropdown')
  setupDropdown('more-toggle', 'more-menu', 'more-dropdown')

  // Mobile nav
  const mobileToggle = document.getElementById('mobile-toggle')
  const mobileNav = document.getElementById('mobile-nav')
  const openIcon = document.getElementById('menu-open-icon')
  const closeIcon = document.getElementById('menu-close-icon')
  if (mobileToggle && mobileNav && openIcon && closeIcon) {
    mobileToggle.addEventListener('click', () => {
      mobileNav.classList.toggle('hidden')
      openIcon.classList.toggle('hidden')
      closeIcon.classList.toggle('hidden')
    })
  }
</script>
