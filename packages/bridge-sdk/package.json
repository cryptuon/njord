{
  "name": "@njord/bridge-sdk",
  "version": "0.1.0",
  "description": "Bridge Operator SDK for Njord Protocol - Run your own fiat on/off ramp",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts src/cli.ts --format cjs,esm --dts --watch",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "solana",
    "bridge",
    "payments",
    "affiliate",
    "njord"
  ],
  "author": "Njord Protocol",
  "license": "MIT",
  "dependencies": {
    "@njord/sdk": "workspace:*",
    "@coral-xyz/anchor": "^0.30.1",
    "@solana/web3.js": "^1.95.4",
    "@solana/spl-token": "^0.4.9",
    "express": "^4.21.2",
    "ioredis": "^5.4.1",
    "zod": "^3.24.1",
    "stripe": "^14.0.0",
    "razorpay": "^2.9.0",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "pino": "^8.17.0",
    "pino-http": "^9.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.1",
    "@types/cors": "^2.8.17",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "bin": {
    "njord-bridge": "./dist/cli.js"
  }
}
