{
  "name": "@njord/indexer",
  "version": "0.1.0",
  "description": "Event Indexer for Njord Protocol - Index on-chain events to PostgreSQL",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts src/cli.ts --format cjs,esm --dts --watch",
    "start": "node dist/cli.js serve",
    "migrate": "node dist/cli.js migrate",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "solana",
    "indexer",
    "postgresql",
    "graphql",
    "njord"
  ],
  "author": "Njord Protocol",
  "license": "MIT",
  "dependencies": {
    "@njord/sdk": "workspace:*",
    "@coral-xyz/anchor": "^0.30.1",
    "@solana/web3.js": "^1.95.4",
    "pg": "^8.13.1",
    "drizzle-orm": "^0.38.3",
    "express": "^4.21.2",
    "@apollo/server": "^4.11.2",
    "graphql": "^16.9.0",
    "graphql-tag": "^2.12.6",
    "pino": "^8.17.0",
    "pino-http": "^9.0.0",
    "zod": "^3.24.1",
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.1",
    "@types/pg": "^8.11.10",
    "drizzle-kit": "^0.30.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "bin": {
    "njord-indexer": "./dist/cli.js"
  }
}
