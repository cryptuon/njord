# Njord Protocol - Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# Solana Configuration
# =============================================================================

# Solana RPC endpoint
# Options: https://api.devnet.solana.com, https://api.mainnet-beta.solana.com
SOLANA_RPC=https://api.devnet.solana.com

# Path to keypair file (for deployments and signing)
KEYPAIR_PATH=~/.config/solana/id.json

# Njord Program ID (update after deployment)
PROGRAM_ID=Fg6PaFpoGXkYsidMpWTK6W2BeZ7FEfcYkg476zPFsLnS

# =============================================================================
# Database Configuration (for Indexer)
# =============================================================================

# PostgreSQL connection string
DATABASE_URL=postgres://njord:njord_dev@localhost:5432/njord_indexer

# =============================================================================
# Redis Configuration
# =============================================================================

# Redis connection URL
REDIS_URL=redis://localhost:6379

# =============================================================================
# API Configuration
# =============================================================================

# Indexer API port
API_PORT=4000

# Bridge API port
BRIDGE_PORT=3000

# API host (0.0.0.0 for Docker, localhost for local dev)
API_HOST=localhost

# =============================================================================
# Payment Providers (Bridge SDK)
# =============================================================================

# Stripe (optional)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Razorpay (optional)
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=...
RAZORPAY_WEBHOOK_SECRET=...

# =============================================================================
# Fraud Detection
# =============================================================================

# Enable fraud detection
FRAUD_DETECTION_ENABLED=true

# Maximum fraud score before auto-rejection (0-100)
MAX_FRAUD_SCORE=80
